public class enemigo3 {
    private int posicionX;
    private int posicionY;

    public enemigo3(int x, int y) {
        this.posicionX = x;
        this.posicionY = y;
    }

    public int getX() {
        return posicionX;
    }

    public int getY() {
        return posicionY;
    }

    public void mover(int filas, int columnas) {

        int direccion = (int) (Math.random() * 4);

        switch (direccion) {
            case 0: // Arriba
                if (posicionX > 1) {
                    posicionX--;
                }
                break;

            case 1: // Abajo
                if (posicionX < filas - 2) {
                    posicionX++;
                }
                break;

            case 2: // Izquierda
                if (posicionY > 1) {
                    posicionY--;
                }
                break;

            case 3: // Derecha
                if (posicionY < columnas - 2) {
                    posicionY++;
                }
                break;
        }
    }
}
