 class enemigo2 {
    private int posicionX;
    private int posicionY;

    public enemigo2(int _x, int _y) {
        this.posicionX = _x;
        this.posicionY = _y;
    }

    public int getX() {
        return posicionX;
    }

    public int getY() {
        return posicionY;
    }

    public void mover() {
        posicionY++;

        if (posicionY > 10) {
            posicionY = 1;
        }
    }
}
