import java.util.Scanner;

public class Pacman {
    private int posicionX;
    private int posicionY;

    public Pacman(int x, int y) {
        this.posicionX = x;
        this.posicionY = y;
    }

    public int getX() {
        return posicionX;
    }

    public int getY() {
        return posicionY;
    }

     public void jugar() {
        Scanner teclado = new Scanner(System.in);
        String movimiento;

        System.out.println("\n=== CONTROLES PACMAN ===");
        System.out.println("W = Arriba");
        System.out.println("A = Izquierda");
        System.out.println("S = Abajo");
        System.out.println("D = Derecha");
        System.out.println("Q = Salir");

        do {
            System.out.print("\nIngresa movimiento: ");
            movimiento = teclado.next().toLowerCase();

            switch (movimiento) {
                case "w":
                    posicionX--;
                    break;
                case "a":
                    posicionY--;
                    break;
                case "s":
                    posicionX++;
                    break;
                case "d":
                    posicionY++;
                    break;
                case "q":
                    System.out.println("Saliendo del control de Pacman...");
                    break;
                default:
                    System.out.println("Instruccion no valida.");
            }

        } while (!movimiento.equals("q"));
    }
}
